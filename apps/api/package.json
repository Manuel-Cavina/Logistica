{
  "name": "@logistica/api",
  "private": true,
  "scripts": {
    "db:generate": "pnpm --filter @logistica/database db:generate",
    "db:migrate": "pnpm --filter @logistica/database db:migrate",
    "db:studio": "pnpm --filter @logistica/database db:studio",
    "prisma:deploy": "pnpm --filter @logistica/database prisma:deploy",
    "prebuild": "pnpm --filter @logistica/shared build && pnpm --filter @logistica/database build",
    "predev": "pnpm --filter @logistica/shared build && pnpm --filter @logistica/database build",
    "pretypecheck": "pnpm --filter @logistica/shared typecheck && pnpm --filter @logistica/database typecheck",
    "dev": "nest start --watch",
    "build": "nest build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@logistica/database": "workspace:*",
    "@logistica/shared": "workspace:*",
    "@nestjs/config": "^4.0.2",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@nestjs/testing": "^11.1.17",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "supertest": "^7.2.2",
    "typescript-eslint": "^8.50.0"
  }
}
