# Entorno
NODE_ENV=development

# Base de datos
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/logistica?schema=public"

# Auth
AUTH_ACCESS_TOKEN_SECRET="replace-with-a-long-random-secret"
AUTH_REFRESH_TOKEN_SECRET="replace-with-a-different-long-random-secret"
AUTH_ACCESS_TOKEN_TTL_SECONDS="900"
AUTH_REFRESH_TOKEN_TTL_SECONDS="604800"
AUTH_REFRESH_COOKIE_NAME="refresh_token"

# API / CORS
API_INTERNAL_URL="http://localhost:3001"
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Pagos — Mercado Pago (E6)
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# Storage — Cloudflare R2 (E7)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Observabilidad
SENTRY_DSN=
